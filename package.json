{
  "name": "codex-workflow-kit-mern-boilerplate",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace client\" \"npm run dev --workspace server\"",
    "build": "npm run build --workspace client",
    "test": "npm run test --workspace client && npm run test --workspace server",
    "test:client": "npm run test --workspace client",
    "test:server": "npm run test --workspace server",
    "test:workflow-routing": "node scripts/validate-frontend-skill-routing.js",
    "test:project-brain": "node scripts/validate-project-brain.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
